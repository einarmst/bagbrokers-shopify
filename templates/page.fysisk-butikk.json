position":"bottom_left","button_background":"#ffffff","button_text_color":"#000000","button_text":"Button","link":""}},"image_WTEYGD":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/IMG_1359.jpg","mobile_image":"shopify:\/\/shop_images\/IMG_1359.jpg","show_overlay":false,"overlay_opacity":30,"text_color":"#ffffff","title":"Velkommen til oss!","content":"Butikksjef Ola Martin","content_position":"bottom_left","button_background":"#ffffff","button_text_color":"#000000","button_text":"Button","link":""}}},"block_order":["image_t9KhNf","image_WTEYGD"],"name":"Slideshow","settings":{"edge_to_edge":false,"section_size":"preserve_ratio","carousel_effect":"slide","autoplay":true,"cycle_speed":5}},"rich_text_gyxnFK":{"type":"rich-text","custom_css":["{padding-top: 50px;}","h2,p {color: #454a4d;}"],"settings":{"text_width":"narrow","title":"Bagbrokers har åpnet fysisk butikk på Slependen senter i Asker!","content":"<p>Etter flere år som ledende nettbutikk innen kofferter, vesker og reiseutstyr, er vi stolte av å kunngjøre at <strong>BagBrokers <\/strong>har åpnet sin aller første fysiske butikk! Butikken blir et nytt midtpunkt for reisende og veskeentusiaster og finner sted på Slependen Senter, sentralt i Asker. Se åpningstider <a href=\"https:\/\/slependensenter.no\/om-oss\/\" target=\"_blank\" title=\"https:\/\/slependensenter.no\/om-oss\/\">her<\/a><\/p><p><\/p>","button_text":"","button_link":"shopify:\/\/collections\/all"}},"image_with_text_p83rjt":{"type":"image-with-text","custom_css":["h2,p {color: #454a4d;}"],"settings":{"image":"shopify:\/\/shop_images\/pexels-mtyutina-249581.jpg","image_position":"left","image_width":45,"title":"En handleopplevelse utenom det vanlige","content":"<p>Nå får du endelig muligheten til å se, føle og utforske vårt brede utvalg av produkter på nært hold. Vi tilbyr alt fra praktiske bagger og reisevesker til stilrene kofferter i høy kvalitet. Enten du planlegger en helgetur eller en lang ferie, vil vår nye butikk ha det du trenger for å gjøre reisen enklere og mer stilfull.<\/p><p><strong>Hvor finner du oss?<\/strong><br\/>Butikken ligger lett tilgjengelig:<\/p><p><strong>Kun 20 minutter fra Oslo sentrum<br\/><\/strong>Rett ved motorveien<\/p><p><strong>Gratis parkering<\/strong> og bussholdeplass like utenfor<br\/>Uansett om du kjører bil eller kommer med kollektivtransport, er det enkelt å besøke oss.<\/p>","button_text":"","button_link":"shopify:\/\/collections\/all"}},"image_with_text_t8d9EM":{"type":"image-with-text","custom_css":["a {color: #ffffff; background: #454a4d;}","h2,p {color: #454a4d;}"],"settings":{"image":"shopify:\/\/shop_images\/tumi_bilde.png","image_position":"right","image_width":50,"title":"TUMI","content":"<p>Vi er spesielt stolte over å introdusere <strong>TUMI™<\/strong>, et globalt anerkjent merke kjent for sin <strong>innovasjon, kvalitet og bærekraftige materialer<\/strong>. TUMIs produkter, som er nøye designet for å møte behovene til moderne reisende, er kun tilgjengelige i vår fysiske butikk. Dette er en sjelden mulighet til å oppleve luksus og funksjonalitet på sitt beste.<\/p>","button_text":"Se mer om Tumi produktene her","button_link":"shopify:\/\/collections\/tumi"}},"image_with_text_overlay_EbRCXC":{"type":"image-with-text-overlay","disabled":true,"custom_css":["{margin-top: 0px !important;}"],"settings":{"image":"shopify:\/\/shop_images\/tumi_bilde.png","title":"","content":"","show_image_overlay":false,"color":"#ffffff"}},"logo_list_3AVPmi":{"type":"logo-list","blocks":{"logo_xWDY6q":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/adax-log_png_62ecc7ae-c5e9-4a11-9156-472cf695d447.png","link":""}},"logo_Wq78Mj":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/victorinox-1-logo-png-transparent_6e00ed4a-fbd5-4bb7-bd61-40cb1ed2e16c.png","link":""}},"logo_9eydXA":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/epic-logo_d7628ac9-098f-4836-af7b-d257f0890a9b.png","link":""}},"logo_Q6fbzy":{"type":"logo","settings":{