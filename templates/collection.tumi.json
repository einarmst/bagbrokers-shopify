{"sections":{"slideshow_F4DF8w":{"type":"slideshow","blocks":{"image_tBfrY3":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/tumi_bild_emindr_elogo.png","show_overlay":false,"overlay_opacity":30,"text_color":"#ffffff","title":"","content":"","content_position":"middle_center","button_background":"#ffffff","button_text_color":"#000000","button_text":"Button","link":""}}},"block_order":["image_tBfrY3"],"settings":{"edge_to_edge":true,"section_size":"small","carousel_effect":"slide","autoplay":true,"cycle_speed":5}},"rich_text_E4xpni":{"type":"rich-text","custom_css":["{padding-top: 40px;}"],"settings":{"text_width":"narrow","title":"","content":"<p><strong>Oppdag TUMI: Kvalitet, Innovasjon og Bærekraft i Hvert Produkt<\/strong><\/p><p>TUMI er ikke bare et merke, det er et symbol på eksepsjonell kvalitet, innovasjon og funksjonalitet. Med et sterkt fokus på holdbarhet og bærekraft, tilbyr TUMI produkter laget av de beste materialene, designet for å møte de høyeste kravene til reisende og hverdagens eventyr.<\/p><p>Hva gjør TUMI unik? <strong>\"The TUMI Difference\"<\/strong> er mer enn bare et slagord. Det er et engasjement for teknisk innovasjon, stil og uovertruffen kvalitet. Alle produktene gjennomgår strenge tester for å sikre at de er slitesterke og pålitelige, og er utstyrt med banebrytende funksjoner som <strong>FXT® Ballistic Nylon<\/strong> og det lettvektige <strong>X-Brace 45®-håndtakssystemet<\/strong>. <\/p><p>Uansett om du er på vei til et viktig møte eller et spennende eventyr, vil TUMIs reisekompagnonger tilby deg den ultimate kombinasjonen av avansert teknologi, tidløst design og praktisk funksjonalitet.<\/p><p><strong>Kjøp din TUMI favoritt nå!<\/strong> Produktene er tilgjengelige eksklusivt i vår fysiske butikk på Slependen Senter, hvor du finner et utvalg av kofferter, bagger, ryggsekker og tilbehøret som gjør reisen enklere og mer stilfull. <a href=\"\/pages\/bagbrokers-slependen-senter\" title=\"Bagbrokers Slependen Senter\">Les mer om butikken her<\/a><\/p>","button_text":"","button_link":"shopify:\/\/collections\/all"}},"mosaic_BziAjt":{"type":"mosaic","blocks":{"item_NjUBxy":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/poly-lifestyle_1_1.jpg","show_overlay":false,"overlay_opacity":50,"background":"#f3f4f4","text_color":"#4f5558","title":"","content":"","content_position":"top_center","button_background":"#ffffff","button_text_color":"#3a2a2f","button_text":"TUMI 19 Degree","link":"shopify:\/\/collections\/tumi-19-degree"}},"item_cQ6nrV":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/19-degree-lifestyle_1.jpg","show_overlay":false,"overlay_opacity":50,"background":"#f3f4f4","text_color":"#4f5558","title":"","content":"","content_position":"top_center","button_background":"#ffffff","button_text_color":"#3a2a2f","button_text":"TUMI 19 Degree Aluminium","link":"shopify:\/\/collections\/tumi-19-degree-aluminium"}},"item_Dr8nhy":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/10291497_fpx.jpg","show_overlay":false,"overlay_opacity":50,"background":"#f3f4f4","text_color":"#4f5558","title":"","content":"","content_position":"bottom_center","button_background":"#ffffff","button_text_color":"#3a2a2f","button_text":"TUMI Alpha 3","link":"shopify:\/\/collections\/tumi-alpha-3"}},"item_eUQD66":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/tumi-alpha-bravo-lando-navigation-backpack-2-rgb-72-1647915804.jpg","show_overlay":false,"overlay_opacity":50,"background":"#f3f4f4","text_color":"#4f5558","title":"","content":"","content_position":"bottom_center","button_background":"#ffffff","button_text_color":"#3a2a2f","button_text":"TUMI Alpha Bravo","link":"shopify:\/\/collections\/tumi-alpha-bravo"}}},"block_order":["item_NjUBxy","item_cQ6nrV","item_Dr8nhy","item_eUQD66"],"settings":{"section_size":"medium"}},"promotion_list_BJTWHD":{"type":"promotion-list","blocks":{"item_TTb4em":{"type":"item","settings":{"image":"shopify:\/\/shop_images\/poly-lifestyl